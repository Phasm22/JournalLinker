# Copy to ~/.config/journal-linker/journal-linker.env and edit paths (no quotes needed).
# Used by journal-linker-*.service units.

JOURNAL_LINKER_REPO=/home/YOU/journalLinker
SCRIBE_JOURNAL_DIR=/home/YOU/Dropbox/path/to/daily-notes
SCRIBE_VOICEDROP_DIR=/home/YOU/Dropbox/VoiceDrop

# Optional (defaults are fine for many setups):
# SCRIBE_MODEL=llama3.1:8b
# SCRIBE_CTX=8192
# SCRIBE_WHISPER_MODEL=base.en
# SCRIBE_JOB_LOG_DIR=/home/YOU/.local/state/journal-linker
# SCRIBE_PUSHOVER_SERVER=https://api.pushover.net
# SCRIBE_PUSHOVER_APP_TOKEN=your-app-token
# SCRIBE_PUSHOVER_USER_KEY=your-user-key
# SCRIBE_PUSHOVER_DEVICE=iphone
# SCRIBE_PUSHOVER_PRIORITY=0
# SCRIBE_DAILY_REFLECTION_WINDOW_START=16:00
# SCRIBE_DAILY_REFLECTION_WINDOW_END=21:00

# Intent pipeline (process_intents.py):
# OPENAI_API_KEY=your-openai-api-key
# INTENT_GATE_MODEL=phi4:14b
# INTENT_GATE_STYLE=auto
# INTENT_ROUTING_MODEL=gpt-4o-mini
# INTENT_CORTEX_DIR=/home/YOU/path/to/cortex
# INTENT_STATE_DIR=/home/YOU/.local/state/journal-linker/intents
# INTENT_CLAUDE_IN_FLIGHT_TTL=300
# INTENT_ENRICHMENT_MODE=off
# LLMLIBRARIAN_SRC=/home/YOU/Desktop/llmLibrarian/src

# Telegram feedback sender (feedback_sender.py):
# TELEGRAM_BOT_TOKEN=your-bot-token
# TELEGRAM_CHAT_ID=your-chat-id
# INTENT_FEEDBACK_DELAY_TODAY=21600
# INTENT_FEEDBACK_DELAY_SOON=86400
# INTENT_FEEDBACK_POLL_TIMEOUT=25
# INTENT_FEEDBACK_SEND_INTERVAL=60
# INTENT_FEEDBACK_DEFER_LIMIT=3
# INTENT_FEEDBACK_MAX_PER_SOURCE_PER_RUN=1
